generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Ponto {
  id        Int      @id @default(autoincrement())
  nome      String
  endereco  String
  bairro    String
  descricao String?
  residuos  String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
